{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
  "resolveJsonModule": true,
  "allowSyntheticDefaultImports": true,
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "baseUrl": ".",
   "paths": {
  "@real-app/libs/prisma": ["./packages/libs/prisma/index"],
  "@real-app/libs/redis": ["./packages/libs/redis/index"],
  "@real-app/errorHandler": ["./packages/errorHandler/index"]
},
    "customConditions": ["@real-app/source"]
  }
}
