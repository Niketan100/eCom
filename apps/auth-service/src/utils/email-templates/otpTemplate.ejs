<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>OTP Verification</title>
        <style>
            body {
                margin: 0;
                padding: 0;
                background-color: #f5f7fb;
                font-family: "Segoe UI", Tahoma, Geneva, Verdana, sans-serif;
                color: #1f2937;
            }
            .container {
                width: 100%;
                padding: 24px 16px;
            }
            .card {
                max-width: 560px;
                margin: 0 auto;
                background: #ffffff;
                border-radius: 16px;
                box-shadow: 0 20px 45px rgba(15, 23, 42, 0.08);
                overflow: hidden;
            }
            .header {
                background: linear-gradient(135deg, #2563eb, #4f46e5);
                color: #ffffff;
                padding: 24px 28px;
            }
            .header h1 {
                margin: 0;
                font-size: 22px;
                font-weight: 600;
            }
            .body {
                padding: 28px;
            }
            .body p {
                margin: 0 0 16px;
                line-height: 1.6;
            }
            .otp {
                display: inline-block;
                font-size: 28px;
                letter-spacing: 6px;
                font-weight: 700;
                color: #111827;
                background: #eef2ff;
                padding: 12px 18px;
                border-radius: 12px;
                margin: 8px 0 20px;
            }
            .meta {
                background: #f8fafc;
                border-radius: 12px;
                padding: 14px 16px;
                color: #475569;
                font-size: 14px;
            }
            .footer {
                padding: 18px 28px 26px;
                font-size: 12px;
                color: #94a3b8;
            }
            .divider {
                height: 1px;
                background: #e2e8f0;
                margin: 20px 0;
            }
            @media (max-width: 480px) {
                .body,
                .header,
                .footer {
                    padding: 20px;
                }
                .otp {
                    font-size: 24px;
                    letter-spacing: 4px;
                }
            }
        </style>
    </head>
    <body>
        <div class="container">
            <div class="card">
                <div class="header">
                    <h1>Verify your sign-in</h1>
                </div>
                <div class="body">
                    <p>Hi <strong><%= name %></strong>,</p>

                    <% if (typeof otp !== 'undefined') { %>
                        <p>Here’s your one-time passcode (OTP). It expires in <strong>5 minutes</strong>.</p>
                        <div class="otp"><%= otp %></div>
                        <div class="meta">
                            If you didn’t request this code, you can safely ignore this email.
                            For security, never share this code with anyone.
                        </div>
                    <% } else { %>
                        <p>We tried to generate your OTP, but something went wrong.</p>
                        <p>Please request a new code in a few minutes.</p>
                    <% } %>

                    <div class="divider"></div>
                    <p>Thanks for choosing RealApp.</p>
                </div>
                <div class="footer">
                    This is an automated email. Please don’t reply to this message.
                </div>
            </div>
        </div>
    </body>
</html>