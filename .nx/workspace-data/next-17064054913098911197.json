{
  "11771556371211733391": {
    "build": {
      "command": "next build",
      "options": {
        "cwd": "apps/seller-ui",
        "tty": false
      },
      "dependsOn": [
        "^build"
      ],
      "cache": true,
      "inputs": [
        "default",
        "^default",
        {
          "externalDependencies": [
            "next"
          ]
        },
        {
          "dependentTasksOutputFiles": "**/*.d.ts",
          "transitive": true
        }
      ],
      "outputs": [
        "{workspaceRoot}/apps/seller-ui/.next/!(cache)/**/*",
        "{workspaceRoot}/apps/seller-ui/.next/!(cache)"
      ],
      "syncGenerators": [
        "@nx/js:typescript-sync"
      ]
    },
    "dev": {
      "continuous": true,
      "command": "next dev",
      "options": {
        "cwd": "apps/seller-ui"
      },
      "syncGenerators": [
        "@nx/js:typescript-sync"
      ]
    },
    "start": {
      "continuous": true,
      "command": "next start",
      "options": {
        "cwd": "apps/seller-ui"
      },
      "dependsOn": [
        "build"
      ]
    },
    "serve-static": {
      "continuous": true,
      "command": "next start",
      "options": {
        "cwd": "apps/seller-ui"
      },
      "dependsOn": [
        "build"
      ]
    },
    "build-deps": {
      "dependsOn": [
        "^build"
      ]
    },
    "watch-deps": {
      "continuous": true,
      "dependsOn": [
        "build-deps"
      ],
      "command": "npx nx watch --projects @real-app/seller-ui --includeDependentProjects -- npx nx build-deps @real-app/seller-ui"
    }
  },
