{
  "12002023708746884569": {
    "build": {
      "command": "next build",
      "options": {
        "cwd": "apps/admin-ui",
        "tty": false
      },
      "dependsOn": [
        "^build"
      ],
      "cache": true,
      "inputs": [
        "default",
        "^default",
        {
          "externalDependencies": [
            "next"
          ]
        },
        {
          "dependentTasksOutputFiles": "**/*.d.ts",
          "transitive": true
        }
      ],
      "outputs": [
        "{workspaceRoot}/apps/admin-ui/.next/!(cache)/**/*",
        "{workspaceRoot}/apps/admin-ui/.next/!(cache)"
      ],
      "syncGenerators": [
        "@nx/js:typescript-sync"
      ]
    },
    "dev": {
      "continuous": true,
      "command": "next dev",
      "options": {
        "cwd": "apps/admin-ui"
      },
      "syncGenerators": [
        "@nx/js:typescript-sync"
      ]
    },
    "start": {
      "continuous": true,
      "command": "next start",
      "options": {
        "cwd": "apps/admin-ui"
      },
      "dependsOn": [
        "build"
      ]
    },
    "serve-static": {
      "continuous": true,
      "command": "next start",
      "options": {
        "cwd": "apps/admin-ui"
      },
      "dependsOn": [
        "build"
      ]
    },
    "build-deps": {
      "dependsOn": [
        "^build"
      ]
    },
    "watch-deps": {
      "continuous": true,
      "dependsOn": [
        "build-deps"
      ],
      "command": "npx nx watch --projects @real-app/admin-ui --includeDependentProjects -- npx nx build-deps @real-app/admin-ui"
    }
  },
